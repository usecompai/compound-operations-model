[Unit]
Description=Compai @BRAND@ · guardrail meta-agent
After=network-online.target compai-mcp.service
Wants=network-online.target
Requires=compai-mcp.service

[Service]
Type=simple
User=@USER@
Group=@USER@
WorkingDirectory=@HOME@/agents/guardrail
Environment="COMPAI_HOME=@HOME@"
Environment="COMPAI_BRAND=@BRAND@"
Environment="COMPAI_AGENT=guardrail"
Environment="COMPAI_AGENT_ROLE=meta-admin"
ExecStart=/usr/bin/python3 @HOME@/services/agent-runner.py --agent guardrail
Restart=on-failure
RestartSec=30
StandardOutput=append:@HOME@/logs/guardrail.log
StandardError=append:@HOME@/logs/guardrail.log

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=@HOME@/logs @HOME@/brain @HOME@/agents/guardrail @HOME@/compliance /tmp

[Install]
WantedBy=multi-user.target
