[Unit]
Description=OperAI @BRAND@ · compliance meta-agent
After=network-online.target operai-mcp.service
Wants=network-online.target
Requires=operai-mcp.service

[Service]
Type=simple
User=@USER@
Group=@USER@
WorkingDirectory=@HOME@/agents/compliance
Environment="OPERAI_HOME=@HOME@"
Environment="OPERAI_BRAND=@BRAND@"
Environment="OPERAI_AGENT=compliance"
Environment="OPERAI_AGENT_ROLE=meta-admin"
ExecStart=/usr/bin/python3 @HOME@/services/agent-runner.py --agent compliance
Restart=on-failure
RestartSec=30
StandardOutput=append:@HOME@/logs/compliance.log
StandardError=append:@HOME@/logs/compliance.log

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=@HOME@/logs @HOME@/brain @HOME@/agents/compliance @HOME@/compliance /tmp

[Install]
WantedBy=multi-user.target
