[Unit]
Description=Compai @BRAND@ · marketing agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@USER@
Group=@USER@
WorkingDirectory=@HOME@/agents/marketing
Environment="COMPAI_HOME=@HOME@"
Environment="COMPAI_BRAND=@BRAND@"
Environment="COMPAI_AGENT=marketing"
ExecStart=/usr/bin/python3 @HOME@/services/agent-runner.py --agent marketing
Restart=on-failure
RestartSec=30
StandardOutput=append:@HOME@/logs/marketing.log
StandardError=append:@HOME@/logs/marketing.log

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=@HOME@/logs @HOME@/brain @HOME@/agents/marketing /tmp

[Install]
WantedBy=multi-user.target
