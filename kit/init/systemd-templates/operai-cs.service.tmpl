[Unit]
Description=Compai @BRAND@ · cs agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@USER@
Group=@USER@
WorkingDirectory=@HOME@/agents/cs
Environment="COMPAI_HOME=@HOME@"
Environment="COMPAI_BRAND=@BRAND@"
Environment="COMPAI_AGENT=cs"
ExecStart=/usr/bin/python3 @HOME@/services/agent-runner.py --agent cs
Restart=on-failure
RestartSec=30
StandardOutput=append:@HOME@/logs/cs.log
StandardError=append:@HOME@/logs/cs.log

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=@HOME@/logs @HOME@/brain @HOME@/agents/cs /tmp

[Install]
WantedBy=multi-user.target
